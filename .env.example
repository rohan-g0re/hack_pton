# Demo HTTP API (server.mjs)
PORT=3000

# Supabase (API + workers + notifier when persisting to DB)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Snapshots / vision (workers)
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Worker process
WORKER_POLL_MS=2500
WORKER_HEALTH_PORT=3031

# Checkout (Knot Shopping) — omit for sandbox stub success
KNOT_API_BASE=https://api.knotapi.com
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=

# macOS notifier HTTP service
PHOTON_HTTP_PORT=3040
PHOTON_NOTIFY_URL=http://127.0.0.1:3040
PHOTON_PROJECT_ID=
PHOTON_SECRET_KEY=
