# Demo HTTP API (server.mjs)
PORT=3000

# Supabase (API + workers + notifier when persisting to DB)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Snapshots / vision (workers)
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash
AWS_S3_BUCKET=
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Worker process
WORKER_POLL_MS=2500
WORKER_HEALTH_PORT=3031

# Checkout (Knot Shopping) — omit for sandbox stub success
KNOT_API_BASE=https://api.knotapi.com
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=

# Notifier HTTP service (runs on worker EC2 — internal only)
PHOTON_HTTP_PORT=3040
PHOTON_NOTIFY_URL=http://127.0.0.1:3040
NOTIFIER_BIND_HOST=127.0.0.1

# Photon iMessage alerts (Spectrum cloud)
# PHOTON_PROJECT_ID and PHOTON_PROJECT_SECRET are required for live delivery.
# The Photon agent is started via: bun services/photon/agent.ts
PHOTON_PROJECT_ID=
PHOTON_PROJECT_SECRET=
# PHOTON_SECRET_KEY is a deprecated alias for PHOTON_PROJECT_SECRET — use PHOTON_PROJECT_SECRET for new setups.
# PHOTON_SECRET_KEY=

# Photon agent tuning
PHOTON_AGENT_POLL_MS=5000
PHOTON_AGENT_BATCH_SIZE=10

# Caretaker fallback phone for smoke testing only — normal sends use the caretaker DB row.
# CARETAKER_PHONE=+1XXXXXXXXXX

# DEPRECATED: PHOTON_SERVER_URL was used by the old direct HTTP sender. Do not use for new setups.
# PHOTON_SERVER_URL=

# Deploy scripts (scripts/.deploy.env — gitignored)
# WEB_HOST=
# WORKER_HOST=
