# ==========================================
# Aegis Project - Comprehensive .gitignore
# ==========================================

# ------------------------------------------
# Node.js / Next.js (Root and Subfolders)
# ------------------------------------------
**/node_modules/
**/.next/
**/out/
**/build/
**/dist/
**/.cache/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*
**/.pnpm-debug.log*
**/.npm/
**/.eslintcache
**/.stylelintcache
**/.prettiercache

# ------------------------------------------
# Secrets, Config & Environment
# ------------------------------------------
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local
**/.env*.local
**/.env.bak
**/.env.tmp
**/config.json
**/secrets.json
**/*.pem
**/*.key
**/*.crt
**/*.pfx
**/*.p12
**/credentials.json

# ------------------------------------------
# IDEs & Editors
# ------------------------------------------
# VS Code / Cursor
**/.vscode/
**/.vscode-test/
**/.cursor/
**/.history/
**/.ionide/
**/project.xcworkspace/

# IntelliJ / WebStorm / PyCharm
**/.idea/
**/*.iws
**/*.iml
**/*.ipr
**/out/
**/cmake-build-*/

# Sublime Text
**/*.sublime-project
**/*.sublime-workspace

# Vim
**/*~
**/.*.swp
**/.*.swo
**/.netrwhist

# ------------------------------------------
# Operating System Files
# ------------------------------------------
# macOS
**/.DS_Store
**/.AppleDouble
**/.LSOverride
**/Icon?
**/.Trashes
**/.Spotlight-V100
**/.fseventsd

# Windows
**/Thumbs.db
**/ehthumbs.db
**/Desktop.ini
**/$RECYCLE.BIN/
**/Folder.jpg
**/AlbumArtSmall.jpg

# Linux
**/*~
**/.fuse_hidden*
**/.directory
**/.Trash-*
**/.nfs*

# ------------------------------------------
# Build Tools & Caches
# ------------------------------------------
**/package-lock.json
**/yarn.lock
**/pnpm-lock.yaml
**/bun.lockb

# TypeScript
**/*.tsbuildinfo
**/next-env.d.ts

# ------------------------------------------
# Deployment & Hosting
# ------------------------------------------
# Vercel
**/.vercel

# Cloudflare
**/.wrangler/
**/dist-wrangler/

# Terraform
**/.terraform/
**/*.tfstate
**/*.tfstate.backup

# AWS
**/.aws/
**/.chalice/

# ------------------------------------------
# Testing & Coverage
# ------------------------------------------
**/coverage/
**/.nyc_output/
**/.jest/
**/junit.xml
**/test-results/

# ------------------------------------------
# Misc / Temporary
# ------------------------------------------
**/*.log
**/*.tmp
**/*.temp
**/*.bak
**/*.swp
**/tmp/
**/temp/
**/.DS_Store
**/_notes
**/dsssh
**/.sass-cache/

# ------------------------------------------
# Database & Storage
# ------------------------------------------
**/*.sqlite
**/*.sqlite-journal
**/*.sqlite-shm
**/*.sqlite-wal
**/*.db
**/*.db-journal
**/*.db-shm
**/*.db-wal
**/dump.rdb
**/*.sql.gz
**/*.sql.bz2

# ------------------------------------------
# Compiled Binaries & Executables
# ------------------------------------------
**/*.exe
**/*.dll
**/*.so
**/*.dylib
**/*.bin
**/*.out
**/*.app
**/*.ipa
**/*.apk

# ------------------------------------------
# Archive & Compressed Files
# ------------------------------------------
**/*.zip
**/*.tar.gz
**/*.tar
**/*.gz
**/*.rar
**/*.7z

# ------------------------------------------
# Logs & Monitoring
# ------------------------------------------
**/*.log
**/logs/
**/error.log
**/access.log
**/.pnpm-debug.log*

# ------------------------------------------
# Project Specific (Aegis)
# ------------------------------------------
# Pencil design tool artifacts (if any are temp/cache)
# Note: .pen files are usually design source and should be kept,
# but if there are export artifacts we should ignore them.
**/docs/design/*.png
**/docs/design/*.jpg
**/docs/design/*.pdf
# Unless explicitly requested to keep exports

# ------------------------------------------
# Jupyter Notebooks (if used)
# ------------------------------------------
**/.ipynb_checkpoints
**/.virtual_envs/
**/venv/
**/.venv/
**/env/
**/bin/
**/lib/
**/include/
