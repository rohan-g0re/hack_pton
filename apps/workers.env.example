# EC2 #2 — worker + notifier (copy to instance as ~/hack_pton/.env)

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

AWS_REGION=us-east-1
AWS_S3_BUCKET=caretaker-snapshots-your-account-id
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.0-flash

KNOT_API_BASE=https://api.knotapi.com
KNOT_CLIENT_ID=
KNOT_CLIENT_SECRET=

WORKER_POLL_MS=2500
WORKER_HEALTH_PORT=3031

# Notifier — same machine; worker calls http://127.0.0.1:3040/notify
PHOTON_HTTP_PORT=3040
PHOTON_NOTIFY_URL=http://127.0.0.1:3040

# Photon (set PHOTON_SERVER_URL from your Photon dashboard)
PHOTON_PROJECT_ID=
PHOTON_SECRET_KEY=
PHOTON_SERVER_URL=
